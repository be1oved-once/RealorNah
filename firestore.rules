// firestore.rules
// Firebase Firestore Security Rules — covers both RealorNah and DoYouKnowMe
//
// COLLECTIONS USED:
//   quizzes      — quiz documents for both projects (shared Firebase project)
//   pins         — RealorNah PIN sync documents  { quizIds: [], updatedAt: "" }
//   dykm_pins    — DoYouKnowMe PIN sync documents { quizIds: [], updatedAt: "" }
//
// DEPLOY:  firebase deploy --only firestore:rules
//
// KEY DESIGN DECISIONS:
//   • No authentication — both apps are intentionally account-free
//   • Quizzes are publicly readable (needed for players to load a quiz by ID)
//   • Quiz creation is open write (client saves on creation)
//   • Quiz update is restricted to only the fields players can write:
//       plays (increment), scores (arrayUnion) — nothing else
//   • Full document overwrites on quizzes are blocked after creation
//   • PIN documents are readable + writable by anyone who knows the PIN ID
//     (the PIN itself is the only "secret" — 6-char alphanumeric)
//   • PIN document size is capped to prevent abuse

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Quizzes ───────────────────────────────────────────────
    // Shared by RealorNah and DoYouKnowMe (both write to "quizzes" collection)
    match /quizzes/{quizId} {

      // Anyone can read a quiz document (needed to load quiz by ID)
      allow read: if true;

      // Create: allow only if the document doesn't already exist AND
      // the incoming data has the required shape
      allow create: if
        !exists(/databases/$(database)/documents/quizzes/$(quizId)) &&
        request.resource.data.keys().hasAll(['quizId','creator','questions','plays','createdAt']) &&
        request.resource.data.plays == 0 &&
        request.resource.data.questions is list &&
        request.resource.data.questions.size() >= 1 &&
        request.resource.data.questions.size() <= 10 &&
        request.resource.data.creator is string &&
        request.resource.data.creator.size() >= 1 &&
        request.resource.data.creator.size() <= 30;

      // Update: only allow the two fields players write (plays + scores),
      // OR allow the creator to update 'questions' only (edit modal)
      allow update: if
        // Player submitting a score — only plays and scores can change
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['plays', 'scores']) &&
          request.resource.data.plays == resource.data.plays + 1
        )
        ||
        // Creator editing questions via edit modal — only questions field changes
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['questions']) &&
          request.resource.data.questions is list &&
          request.resource.data.questions.size() >= 1 &&
          request.resource.data.questions.size() <= 10
        );

      // Delete: allow (creator deletes their own quiz — no auth, so open)
      allow delete: if true;
    }

    // ── RealorNah PIN sync ────────────────────────────────────
    match /pins/{pinId} {
      // Anyone who knows the PIN can read and write their sync doc
      allow read: if true;

      // Write: only allow if the doc has the expected shape and quizIds is a list
      allow write: if
        request.resource.data.keys().hasAll(['quizIds', 'updatedAt']) &&
        request.resource.data.quizIds is list &&
        request.resource.data.quizIds.size() <= 50 &&
        request.resource.data.updatedAt is string &&
        // Cap document size to ~5KB to prevent abuse
        request.resource.size() < 5120;
    }

    // ── DoYouKnowMe PIN sync ──────────────────────────────────
    match /dykm_pins/{pinId} {
      allow read: if true;

      allow write: if
        request.resource.data.keys().hasAll(['quizIds', 'updatedAt']) &&
        request.resource.data.quizIds is list &&
        request.resource.data.quizIds.size() <= 50 &&
        request.resource.data.updatedAt is string &&
        request.resource.size() < 5120;
    }

    // ── Block everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
